    given-names: "Rudolf J."
    orcid: "https://orcid.org/0009-0009-6557-8843"
    affiliation: "Violet Sky Security SEZC (Cayman Islands)"
repository-code: "https://github.com/rudizee007/spt-txn-poc"
url: "https://foss.violetskysecurity.com"
license: Apache-2.0
keywords:
  - authorization
  - FATF Travel Rule
  - zero-knowledge proofs
  - selective disclosure
  - OAuth Transaction Tokens
  - capability tokens
  - agentic authorization
  - post-quantum cryptography
  - privacy-preserving compliance
  - blockchain-agnostic
